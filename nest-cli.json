{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "sourceRoot": "src",
    "compilerOptions": {
        "deleteOutDir": true,
        "builder": "swc",
        "typeCheck": true,
        "webpack": false,
        "assets": [
            {
                "include": "languages/**/*",
                "outDir": "./dist"
            }
        ]
    }
}
