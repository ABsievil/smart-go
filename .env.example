NODE_ENV=development

DATABASE_URI=
DATABASE_DEBUG=

APP_NAME=
APP_VERSION=

APP_HOST=
APP_PORT=
APP_TIMEZONE=
APP_LANGUAGE=

APP_GLOBAL_PREFIX=
API_VERSION=

# AES-256 encryption/decryption secret
ENCRYPTION_SECRET=change-me-to-a-strong-secret
ENCRYPTION_ALGORITHM=aes-256-cbc

JWT_SECRET=your-super-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Register both callback URLs in Google Cloud Console
GOOGLE_OAUTH_CALLBACK_URL_WEB=${SERVER_URI}/api/v1/auth/google/callback/web
GOOGLE_OAUTH_CALLBACK_URL_APP=${SERVER_URI}/api/v1/auth/google/callback/app
# Legacy fallback for web callback when GOOGLE_OAUTH_CALLBACK_URL_WEB is unset
GOOGLE_OAUTH_CALLBACK_URL=
# Client redirect after OAuth (web page / mobile deep link)
GOOGLE_OAUTH_REDIRECT_URL_WEB=http://localhost:3000/auth/callback
GOOGLE_OAUTH_REDIRECT_URL_APP=myapp://auth/callback
# Legacy fallback for app redirect
GOOGLE_OAUTH_MOBILE_REDIRECT_URL=
GOOGLE_OAUTH_AUTH_CODE_TTL_SECONDS=120

# VNPAY Sandbox
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=
# Gateway callbacks (register both URLs in VNPAY merchant portal)
VNPAY_RETURN_URL_WEB=${APP_URI}/api/v1/payments/vnpay/return/web
VNPAY_RETURN_URL_APP=${APP_URI}/api/v1/payments/vnpay/return/app
# Legacy fallback for web when VNPAY_RETURN_URL_WEB is unset
VNPAY_RETURN_URL=
# Client redirect after verify (web page / mobile deep link)
VNPAY_REDIRECT_URL_WEB=http://localhost:3000/payment/result
VNPAY_REDIRECT_URL_APP=smartgo://payment/result
VNPAY_LOCALE=vn

# MoMo Sandbox
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=
MOMO_RETURN_URL_WEB=${APP_URI}/api/v1/payments/momo/return/web
MOMO_RETURN_URL_APP=${APP_URI}/api/v1/payments/momo/return/app
MOMO_RETURN_URL=
MOMO_REDIRECT_URL_WEB=http://localhost:3000/payment/result
MOMO_REDIRECT_URL_APP=smartgo://payment/result
MOMO_IPN_URL=
MOMO_REQUEST_TYPE=captureWallet
MOMO_AUTO_CAPTURE=true
MOMO_LANG=vi

APP_CORS_ORIGINS=
APP_CORS_METHODS=
APP_CORS_HEADERS=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_SECURE=true

# Redis
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=smart-go:

# DashScope (Alibaba Cloud — Qwen LLM + text-embedding-v4)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen3.5-35b-a3b
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSION=1536
DASHSCOPE_MAX_NEW_TOKENS=1024
DASHSCOPE_TEMPERATURE=0.7
DASHSCOPE_ENABLE_THINKING=false

# Zilliz Cloud
ZILLIZ_URI=
ZILLIZ_TOKEN=
ZILLIZ_COLLECTION_NAME=smart_go_knowledge
ZILLIZ_DIMENSION=1536
ZILLIZ_MIN_SCORE=0.35

# Chatbot
CHATBOT_CONTEXT_LIMIT=3
CHATBOT_EMBED_BATCH_SIZE=64
CHATBOT_CACHE_ENABLED=true
CHATBOT_CACHE_EMBEDDING_TTL=604800
CHATBOT_CACHE_REPLY_TTL=600
# Snapshot lịch sử theo conversation (Redis), mặc định 2h
CHATBOT_CACHE_HISTORY_TTL=7200