NODE_ENV=development

DATABASE_URI=
DATABASE_DEBUG=

APP_NAME=
APP_VERSION=

APP_HOST=
APP_PORT=
APP_TIMEZONE=
APP_LANGUAGE=

APP_GLOBAL_PREFIX=
API_VERSION=

JWT_SECRET=your-super-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=
GOOGLE_OAUTH_MOBILE_REDIRECT_URL=
GOOGLE_OAUTH_AUTH_CODE_TTL_SECONDS=120

# VNPAY Sandbox
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=
VNPAY_RETURN_URL=
VNPAY_LOCALE=vn

APP_CORS_ORIGINS=
APP_CORS_METHODS=
APP_CORS_HEADERS=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_SECURE=true

# Redis
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=smart-go:

# DashScope (Alibaba Cloud — Qwen LLM + text-embedding-v4)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen3.5-35b-a3b
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSION=1536
DASHSCOPE_MAX_NEW_TOKENS=1024
DASHSCOPE_TEMPERATURE=0.7
DASHSCOPE_ENABLE_THINKING=false

# Zilliz Cloud
ZILLIZ_URI=
ZILLIZ_TOKEN=
ZILLIZ_COLLECTION_NAME=smart_go_knowledge
ZILLIZ_DIMENSION=1536
ZILLIZ_MIN_SCORE=0.35

# Chatbot
CHATBOT_CONTEXT_LIMIT=5
CHATBOT_EMBED_BATCH_SIZE=64